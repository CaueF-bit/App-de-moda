# ===========================================
#  APLICAÇÃO
# ===========================================
# Em dev: development. Em produção: production
NODE_ENV=development

# Em dev, qualquer porta livre. Em produção (Railway/Render),
# o serviço sobrescreve isso com a porta real (geralmente via $PORT).
PORT=3000

# debug | info | warn | error
LOG_LEVEL=debug


# ===========================================
#  BANCO DE DADOS
# ===========================================
#
#  DEV (SQLite):
#    DATABASE_URL="file:./prisma/dev.db"
#
#  PRODUÇÃO (Postgres no Railway):
#    O Railway injeta DATABASE_URL automaticamente quando você
#    adiciona o plugin de Postgres. Algo como:
#    DATABASE_URL="postgresql://user:pass@host.railway.app:5432/railway"
#
#    Lembre de mudar provider no prisma/schema.prisma pra "postgresql"
#    antes de fazer deploy.
# ===========================================
DATABASE_URL="file:./prisma/dev.db"


# ===========================================
#  AUTENTICAÇÃO JWT
# ===========================================
# Em DEV pode ser qualquer string com 32+ caracteres.
# Em PRODUÇÃO gere um segredo forte e único com:
#   npm run generate-secret
JWT_SECRET="troque-este-segredo-em-producao-com-no-minimo-32-caracteres"
JWT_EXPIRES_IN=7d


# ===========================================
#  INTEGRAÇÃO COM CLAUDE (Anthropic) — opcional
# ===========================================
# Sem isso, o app usa o recomendador heurístico (sem IA).
# Pegue uma chave em https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
AI_ENABLED=false


# ===========================================
#  SEGURANÇA
# ===========================================
# Em DEV: * (libera tudo).
# Em PRODUÇÃO: domínios separados por vírgula. Exemplo:
#   CORS_ORIGIN=https://app-de-moda.com,https://www.app-de-moda.com
CORS_ORIGIN=*

# Janela e limite de rate limit (ajuste pro seu tráfego em produção)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
