{
  "name": "app-de-moda",
  "version": "1.0.0",
  "description": "API profissional para recomendacao de looks, mala inteligente e feedback de estilo com IA.",
  "private": true,
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:tsx": "tsx src/index.ts",
    "build": "prisma generate && tsc --outDir dist",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:reset": "prisma migrate reset",
    "prisma:studio": "prisma studio",
    "db:push": "prisma db push",
    "postinstall": "prisma generate",
    "start:prod": "prisma migrate deploy && node dist/index.js",
    "generate-secret": "node -e \"console.log(require('crypto').randomBytes(64).toString('hex'))\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@prisma/client": "^5.20.0",
    "argon2": "^0.41.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.16.0",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.6",
    "prisma": "^5.20.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vitest": "^2.1.1"
  },
  "engines": {
    "node": ">=18"
  }
}
