// =========================================================================
//  Schema do banco
// =========================================================================
//
//  PROD (Vercel) → PostgreSQL hospedado (Neon / Vercel Postgres).
//  DEV local     → também PostgreSQL. Para usar SQLite no dev, troque o
//                  provider para "sqlite" temporariamente (não commitar).
//
//  DATABASE_URL é configurada nas Environment Variables da Vercel.
//  Use sempre a connection string COM POOLING (serverless abre muitas
//  conexões — sem pooling o Postgres esgota o limite).
//
//  binaryTargets inclui o runtime da Vercel (Amazon Linux / OpenSSL 3)
//  além do "native" para rodar local.
// =========================================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Usuário da plataforma — tabela usada pela autenticação.
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  name          String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  profile       UserProfile?
  wardrobe      WardrobeItem[]
  outfits       Outfit[]
  preferences   Preference?
}

/// Perfil estendido do usuário (medidas, paleta, preferências de estilo).
model UserProfile {
  userId               String   @id
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  bodyType             String
  preferredFits        String   // JSON: string[]
  measurements         String   // JSON: UserMeasurements
  personalPalette      String   // JSON: PersonalColorPalette
  dislikedPatterns     String?  // JSON: string[]
  favoriteCategories   String?  // JSON: ClothingCategory[]
  fragrancePreferences String?  // JSON: string[]
  budgetLimit          Float    @default(0)

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

/// Peça do guarda-roupa.
model WardrobeItem {
  id              String   @id
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  imageUrl        String
  category        String
  layer           String?
  subcategory     String?
  color           String
  secondaryColor  String?
  pattern         String?
  brand           String?
  fabric          String?
  idealSeason     String?  // JSON: SeasonType[]
  fit             String?
  formality       String?
  tags            String?  // JSON: StyleTag[]
  confidence      Float?
  isConfirmed     Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

/// Outfit salvo (gerado pela recomendação + feedback).
model Outfit {
  id            String   @id
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title         String
  reasoning     String
  occasion      String?
  score         Float    @default(0)
  payload       String   // JSON: OutfitSuggestion completo (upper, lower, shoes, etc.)
  feedback      String?  // "like" | "dislike"
  feedbackTags  String?  // JSON: string[]

  createdAt     DateTime @default(now())

  @@index([userId])
}

/// Pesos de preferência aprendidos com o feedback do usuário.
model Preference {
  userId              String   @id
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  favoriteColors      String   @default("{}")  // JSON: Record<string, number>
  favoriteCategories  String   @default("{}")  // JSON: Record<ClothingCategory, number>
  favoriteOccasions   String   @default("{}")  // JSON: Record<string, number>

  updatedAt           DateTime @updatedAt
}
